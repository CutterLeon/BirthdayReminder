# Vite: nur Variablen mit Prefix VITE_
# Werte: Supabase → Project Settings → API

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Supabase Edge Functions (im Supabase Dashboard als Secrets setzen, nicht als VITE_)
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - CRON_SECRET (für Cron-getriggerte Functions wie daily-reminders, monitor-links)
# - RESEND_API_KEY + optional RESEND_FROM (für Geburtstags-Mails)
